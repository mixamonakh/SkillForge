NODE_ENV=development
APP_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:4000
API_PUBLIC_BASE_PATH=/api/v1
NEXT_PUBLIC_API_BASE_PATH=/api/v1
DATABASE_URL=postgresql://skillforge:skillforge@localhost:5432/skillforge?schema=public
POSTGRES_USER=skillforge
POSTGRES_PASSWORD=skillforge
POSTGRES_DB=skillforge
POSTGRES_VOLUME_NAME=skillforge_postgres_data
LOG_LEVEL=info
DEFAULT_USER_NAME=Михаил
DEFAULT_LOCALE=ru
SEED_CONTENT_PACKS=js-baseline-v1,js-prebaseline-v1
SEED_CONTENT_PACK=
AI_MODE=manual
AI_PROVIDER=openai
AI_FAKE_PROVIDER_ENABLED=false
AI_MONTHLY_BUDGET_USD=10
AI_ATTEMPT_REVIEW_ENABLED=false
AI_CONTENT_REVIEW_ENABLED=false
AI_NUDGE_ENABLED=false
OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION_ID=
OPENAI_MODEL_ATTEMPT_EVALUATION=gpt-5.6-luna
OPENAI_MODEL_CONTENT_REVIEW=gpt-5.6-luna
OPENAI_MODEL_NUDGE=gpt-5.6-luna
OPENAI_MODEL_ESCALATION=gpt-5.6-terra
OPENAI_PRICE_INPUT_USD_PER_MILLION=
OPENAI_PRICE_CACHED_INPUT_USD_PER_MILLION=
OPENAI_PRICE_OUTPUT_USD_PER_MILLION=
IMPORT_MAX_BYTES=5242880
CODE_RUNNER_TIMEOUT_MS=2000
RESUME_THRESHOLD_DAYS=7
