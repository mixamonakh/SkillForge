{
  "name": "@skillforge/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx src/main.ts",
    "start:prod": "node dist/main.js",
    "lint": "eslint src test --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "openapi:generate": "tsx src/openapi.ts",
    "ai:smoke": "tsx src/scripts/ai-api-cli.ts smoke",
    "ai:usage": "tsx src/scripts/ai-api-cli.ts usage"
  },
  "dependencies": {
    "@fastify/helmet": "13.1.0",
    "@fastify/static": "9.3.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@skillforge/ai-provider": "workspace:*",
    "@skillforge/contracts": "workspace:*",
    "@skillforge/db": "workspace:*",
    "@skillforge/learning-engine": "workspace:*",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "fastify": "5.10.0",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.1.10",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
