{
  "$ref": "#/definitions/SkillForgeAnalysisV1",
  "definitions": {
    "SkillForgeAnalysisV1": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "1.0"
        },
        "contract": {
          "type": "string",
          "const": "skillforge-analysis-v1"
        },
        "sourceBundleId": {
          "type": "string",
          "format": "uuid"
        },
        "evaluator": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "external-ai"
            },
            "model": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            },
            "analyzedAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "kind",
            "analyzedAt"
          ],
          "additionalProperties": false
        },
        "attemptEvaluations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "attemptId": {
                "type": "string",
                "format": "uuid"
              },
              "overallScore": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "passed": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "reliability": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "default": 0.65
              },
              "dimensions": {
                "type": "object",
                "additionalProperties": {
                  "$ref": "#/definitions/SkillForgeAnalysisV1/properties/attemptEvaluations/items/properties/overallScore"
                }
              },
              "feedbackMarkdown": {
                "type": "string",
                "maxLength": 250000
              },
              "misconceptions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "key": {
                      "$ref": "#/definitions/SkillForgeAnalysisV1/properties/evaluator/properties/model"
                    },
                    "title": {
                      "$ref": "#/definitions/SkillForgeAnalysisV1/properties/evaluator/properties/model"
                    },
                    "evidence": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 10000
                    },
                    "remediation": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 10000
                    }
                  },
                  "required": [
                    "key",
                    "title",
                    "evidence",
                    "remediation"
                  ],
                  "additionalProperties": false
                },
                "maxItems": 100
              },
              "topicEvidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "topicKey": {
                      "$ref": "#/definitions/SkillForgeAnalysisV1/properties/evaluator/properties/model"
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "RECALL",
                        "EXPLANATION",
                        "PREDICT_OUTPUT",
                        "DEBUGGING",
                        "CODE_CORRECTNESS",
                        "EDGE_CASES",
                        "COMPLEXITY_REASONING",
                        "INTERVIEW_RESPONSE",
                        "TRANSFER",
                        "BATTLE",
                        "AI_REVIEW",
                        "SELF_REPORT"
                      ]
                    },
                    "score": {
                      "$ref": "#/definitions/SkillForgeAnalysisV1/properties/attemptEvaluations/items/properties/overallScore"
                    }
                  },
                  "required": [
                    "topicKey",
                    "kind",
                    "score"
                  ],
                  "additionalProperties": false
                },
                "maxItems": 200
              }
            },
            "required": [
              "attemptId",
              "overallScore",
              "passed",
              "dimensions",
              "feedbackMarkdown",
              "misconceptions",
              "topicEvidence"
            ],
            "additionalProperties": false
          },
          "maxItems": 5000
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "topicKey": {
                "$ref": "#/definitions/SkillForgeAnalysisV1/properties/evaluator/properties/model"
              },
              "priority": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5
              },
              "sessionMode": {
                "type": "string",
                "enum": [
                  "ASSESSMENT",
                  "TRAINING",
                  "REVIEW",
                  "INTERVIEW",
                  "RETURN",
                  "BATTLE"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1,
                "maxLength": 10000
              }
            },
            "required": [
              "topicKey",
              "priority",
              "sessionMode",
              "reason"
            ],
            "additionalProperties": false
          },
          "maxItems": 500
        },
        "summary": {
          "type": "string",
          "maxLength": 250000
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 10000
          },
          "maxItems": 500,
          "default": []
        }
      },
      "required": [
        "schemaVersion",
        "contract",
        "sourceBundleId",
        "evaluator",
        "attemptEvaluations",
        "recommendations",
        "summary"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
