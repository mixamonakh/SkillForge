{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": [
    "scripts/**/*.ts",
    "eslint.config.mjs",
    "apps/*/*.config.ts",
    "packages/*/*.config.ts"
  ],
  "exclude": ["node_modules", "**/dist/**"]
}
